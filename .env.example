# Docker Compose environment variables.
# Copy this file to .env for local Docker startup. Do not commit .env.

MYSQL_ROOT_PASSWORD=interview_agent_dev

PLATFORM_JWT_SECRET=replace-with-at-least-32-bytes-secret
PLATFORM_DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key

PLATFORM_CORS_ALLOWED_ORIGINS=http://localhost:5173,https://localhost:5173
PLATFORM_SSL_ENABLED=false

# Optional MinIO settings, used after MinIO storage is enabled.
PLATFORM_MINIO_ACCESS_KEY=minioadmin
PLATFORM_MINIO_SECRET_KEY=replace-with-minio-secret
PLATFORM_MINIO_BUCKET=interview-agent
PLATFORM_MINIO_PUBLIC_URL=http://localhost:9000
