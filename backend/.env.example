# Backend local runtime environment.
# Copy this file to backend/.env, fill real values, then run:
# set -a; source backend/.env; set +a; cd backend && ./mvnw spring-boot:run

SPRING_PROFILES_ACTIVE=dev

PLATFORM_SERVER_PORT=8442
PLATFORM_SSL_ENABLED=true
PLATFORM_SSL_KEY_STORE=classpath:springboot-local.p12
PLATFORM_SSL_KEY_STORE_PASSWORD=changeit
PLATFORM_SSL_KEY_STORE_TYPE=PKCS12
PLATFORM_SSL_KEY_ALIAS=1

PLATFORM_DB_URL=jdbc:mysql://localhost:3306/interview_agent
PLATFORM_DB_USERNAME=root
PLATFORM_DB_PASSWORD=replace-with-local-db-password

PLATFORM_REDIS_HOST=localhost
PLATFORM_REDIS_PORT=6379
PLATFORM_REDIS_PASSWORD=
PLATFORM_REDIS_DATABASE=0

PLATFORM_JWT_SECRET=replace-with-at-least-32-bytes-secret
PLATFORM_JWT_EXPIRATION=604800000

PLATFORM_DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key
PLATFORM_DEEPSEEK_BASE_URL=https://api.deepseek.com
PLATFORM_DEEPSEEK_MODEL=deepseek-v4-flash
PLATFORM_DEEPSEEK_TEMPERATURE=0.5

PLATFORM_XUNFEI_APPID=
PLATFORM_XUNFEI_API_KEY=
PLATFORM_XUNFEI_API_SECRET=
PLATFORM_XUNFEI_OST_APP_ID=
PLATFORM_XUNFEI_OST_API_KEY=
PLATFORM_XUNFEI_OST_API_SECRET=

PLATFORM_CORS_ALLOWED_ORIGINS=https://localhost:5173,http://localhost:5173
PLATFORM_SWAGGER_ENABLED=true
PLATFORM_LOG_LEVEL=DEBUG

# Optional MinIO settings, used after MinIO storage is enabled.
PLATFORM_STORAGE_TYPE=minio
PLATFORM_MINIO_ENDPOINT=http://localhost:9000
PLATFORM_MINIO_PUBLIC_URL=http://localhost:9000
PLATFORM_MINIO_ACCESS_KEY=minioadmin
PLATFORM_MINIO_SECRET_KEY=replace-with-minio-secret
PLATFORM_MINIO_BUCKET=interview-agent
