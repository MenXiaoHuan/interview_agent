schema {
  query: Query
  mutation: Mutation
}

scalar DateTime
scalar JSON

type User {
  id: ID!
  username: String!
  password: String
  nickname: String
  avatarUrl: String
  userType: Int
  email: String
  phone: String
  gender: Int
  status: Int
  eyeCareMode: Int
  surpriseMode: Int
  lastLoginAt: DateTime
  createdAt: DateTime
  updatedAt: DateTime
}

type UserSettings {
  eyeCareMode: Int!
}

type JobCategory {
  id: ID!
  name: String!
  level: Int!
  parentId: ID
  sortOrder: Int
  status: Int
  createdAt: DateTime
  updatedAt: DateTime
  children: [JobCategory!]
}

type Job {
  id: ID!
  categoryId: ID!
  category: JobCategory
  name: String!
  description: String
  requirements: String
  status: Int
  createdAt: DateTime
  updatedAt: DateTime
}

"""
选择题对象。
当前 options 在存储层是字符串，迁移时可通过 resolver 解析为列表。
"""
type ChoiceQuestion {
  id: ID!
  jobId: ID!
  question: String!
  options: [String!]
  correctAnswer: String
  explanation: String
  difficulty: Int
  score: Int
  createdAt: DateTime
  updatedAt: DateTime
}

type ScenarioQuestion {
  id: ID!
  jobId: ID!
  question: String!
  createdAt: DateTime
  updatedAt: DateTime
}

type ChoiceQuestionRecord {
  id: ID!
  userId: ID!
  jobId: ID!
  totalScore: Int
  correctCount: Int
  correctRate: Float
  duration: Int
  status: Int
  evaluationType: String
  createdAt: DateTime
  updatedAt: DateTime
}

type InterviewSubmitQuestionResult {
  questionId: ID!
  question: String
  userAnswer: String
  correctAnswer: String
  isCorrect: Boolean
  score: Int
}

type InterviewSubmitResult {
  interviewId: ID!
  totalScore: Int
  correctCount: Int
  correctRate: Float
  questions: [InterviewSubmitQuestionResult!]!
}

type InterviewResultQuestion {
  id: ID
  question: String
  options: [String!]
  correctAnswer: String
  userAnswer: String
  explanation: String
}

type InterviewResult {
  totalScore: Int
  correctCount: Int
  correctRate: Float
  questions: [InterviewResultQuestion!]!
}

type ResumeFeedback {
  advantages: String
  disadvantages: String
  improvementSuggestions: String
}

type ResumeCompetenciesScore {
  professionalSkills: Int
  projectExecution: Int
  innovation: Int
  communication: Int
  adaptability: Int
}

type ResumeAnalysisHistory {
  id: ID!
  userId: ID!
  jobId: ID
  resumeContent: String
  score: Int
  advantages: String
  disadvantages: String
  improvementSuggestions: String
  professionalSkills: Int
  projectExecution: Int
  innovation: Int
  communication: Int
  adaptability: Int
  createdAt: DateTime
  updatedAt: DateTime
  evaluationType: String
}

type ResumeContent {
  resumeId: ID!
  content: String!
}

type ScenarioAnalysis {
  id: ID!
  userId: ID!
  totalScore: Int
  score1: Int
  suggestion1: String
  score2: Int
  suggestion2: String
  score3: Int
  suggestion3: String
  score4: Int
  suggestion4: String
  score5: Int
  suggestion5: String
  evaluationType: String
  createTime: DateTime
  updateTime: DateTime
}

type ComprehensiveResumeHistory {
  id: ID!
  userId: ID!
  jobId: ID
  fileName: String
  fileSize: Int
  fileType: String
  uploadTime: DateTime
  overallScore: Int
  skillMatch: Int
  experienceMatch: Int
  educationMatch: Int
  communicationSkill: Int
  leadershipSkill: Int
  aiAnalysis: String
  aiSuggestions: String
}

type ComprehensiveQuestionHistory {
  id: ID!
  userId: ID!
  jobId: ID
  startTime: DateTime
  endTime: DateTime
  totalTime: Int
  overallScore: Int
  aiSuggestions: String
}

type ComprehensiveScenarioHistory {
  id: ID!
  userId: ID!
  jobId: ID
  startTime: DateTime
  endTime: DateTime
  totalTime: Int
  overallScore: Int
  fluencyScore: Int
  emotionScore: Int
  relevanceScore: Int
  adaptabilityScore: Int
  aiAssessment: String
}

type ComprehensiveReport {
  id: ID!
  userId: ID!
  jobId: ID
  job: Job
  jobTitle: String
  overallScore: Float
  resumeScore: Float
  questionScore: Float
  scenarioScore: Float
  strengthAnalysis: String
  improvementAnalysis: String
  learningRoute: String
  createTime: DateTime
}

type ComprehensiveReportHistory {
  id: ID!
  userId: ID!
  jobId: ID
  job: Job
  overallScore: Float
  resumeScore: Float
  questionScore: Float
  scenarioScore: Float
  strengthAnalysis: String
  improvementAnalysis: String
  learningRoute: String
  createTime: DateTime
}

type Feedback {
  id: ID!
  userId: ID!
  type: String!
  title: String!
  content: String!
  status: String!
  reply: String
  replyTime: DateTime
  adminId: ID
  adminName: String
  createdAt: DateTime
  updatedAt: DateTime
}

type FeedbackItem {
  id: ID!
  userId: ID!
  nickname: String
  type: String!
  title: String!
  content: String!
  status: String!
  createdAt: DateTime
  updatedAt: DateTime
}

type FeedbackStatus {
  id: ID!
  title: String!
  status: String!
  reply: String
  replyTime: DateTime
  updatedAt: DateTime
}

type Blessing {
  id: ID!
  userId: ID!
  content: String!
  type: String
  status: String
  createdAt: DateTime
  updatedAt: DateTime
}

type BlessingSummary {
  id: ID!
  content: String!
  type: String
  status: String
  createdAt: DateTime
  updatedAt: DateTime
}

type ChatMessage {
  id: ID!
  userId: ID!
  content: String!
  createdAt: DateTime
}

type ChatMessageView {
  id: ID!
  userId: ID!
  nickname: String
  avatarUrl: String
  content: String!
  createdAt: DateTime
}

type AgentConversationMessageResponse {
  type: String!
  content: String!
  time: String
}

type AgentConversationMemoryResponse {
  sessionId: ID!
  summaryHash: String
  summaryContent: String
  recentTurns: JSON
  createdAt: DateTime
  updatedAt: DateTime
}

type AgentConversationResponse {
  id: ID!
  jobId: ID
  agentKey: String
  title: String
  preview: String
  hasInteractedWithAssistant: Boolean
  hasShownWelcomeMessage: Boolean
  selectedEvaluationMode: String
  assistantActions: JSON
  eventLogs: JSON
  aiMessages: [AgentConversationMessageResponse!]!
  comprehensiveState: JSON
  firstQuestionAt: DateTime
  createdAt: DateTime
  updatedAt: DateTime
}

type RankingEntry {
  userId: ID!
  nickname: String
  avatarUrl: String
  score: Float
  rank: Int
}

type ResetCode {
  contact: String!
  channel: String
  code: String
  createdAt: DateTime
  expiresAt: DateTime
}

type Query {
  rsaPublicKey: String!
  me: User
  users(page: Int! = 1, size: Int! = 10): [User!]!

  jobCategoryTree: [JobCategory!]!
  jobCategoryName(categoryId: ID!): String!
  jobs(categoryId: ID!): [Job!]!
  allJobs: [Job!]!
  job(id: ID!): Job

  allChoiceQuestions: [ChoiceQuestion!]!
  choiceQuestions(jobId: ID!): [ChoiceQuestion!]!
  interviewResult(interviewQuestionRecordId: ID!): InterviewResult!
  interviewRecords(userId: ID!, evaluationType: String = "SPECIAL"): [ChoiceQuestionRecord!]!
  interviewRecordsByJob(userId: ID!, jobId: ID!, evaluationType: String = "SPECIAL"): [ChoiceQuestionRecord!]!

  allScenarioQuestions: [ScenarioQuestion!]!
  scenarioQuestions(jobId: ID!): [ScenarioQuestion!]!

  resumeAnalysisHistories(userId: ID!, evaluationType: String = "SPECIAL"): [ResumeAnalysisHistory!]!
  resumeAnalysisHistory(resumeHistoryId: ID!): ResumeAnalysisHistory
  scenarioAnalysisHistories(userId: ID!, evaluationType: String = "SPECIAL"): [ScenarioAnalysis!]!

  comprehensiveReport(id: ID!): ComprehensiveReport
  userComprehensiveReports(userId: ID!): [ComprehensiveReport!]!

  feedbackList: [FeedbackItem!]!
  feedback(id: ID!): Feedback
  myFeedbackStatus: [FeedbackStatus!]!

  blessings(status: String, type: String): [BlessingSummary!]!
  blessing(id: ID!): Blessing

  chatMessages(days: Int = 1): [ChatMessageView!]!
  agentConversations(agentKey: String): [AgentConversationResponse!]!
  agentConversationMessages(sessionId: ID!): [AgentConversationMessageResponse!]!
  agentConversationEvents(sessionId: ID!): JSON!
  agentConversationMemory(sessionId: ID!): AgentConversationMemoryResponse

  comprehensiveResumeRankings(jobId: ID, size: Int = 50): [RankingEntry!]!
  comprehensiveQuestionRankings(jobId: ID, size: Int = 50): [RankingEntry!]!
  comprehensiveScenarioRankings(jobId: ID, size: Int = 50): [RankingEntry!]!

  specializedResumeRankings(jobId: ID, evaluationType: String, size: Int = 50): [RankingEntry!]!
  specializedQuestionRankings(jobId: ID, evaluationType: String, size: Int = 50): [RankingEntry!]!
  specializedScenarioRankings(evaluationType: String, size: Int = 50): [RankingEntry!]!

  latestResetCode(contact: String!): ResetCode
  queryTranscriptionTask(taskId: String!): String!
}

type Mutation {
  register(input: RegisterInput!): JSON!
  login(input: LoginInput!): JSON!
  sendResetCode(input: ForgotSendCodeInput!): Boolean!
  resetPassword(input: ForgotResetInput!): Boolean!

  updateEyeMode(input: UpdateEyeModeInput!): UserSettings!
  updateSurpriseMode(input: UpdateSurpriseModeInput!): JSON!
  updateNickname(input: UpdateNicknameInput!): JSON!
  updateAvatar(input: UpdateAvatarInput!): Boolean!
  updatePassword(input: UpdatePasswordInput!): Boolean!
  bindEmail(input: BindEmailInput!): Boolean!
  bindPhone(input: BindPhoneInput!): Boolean!
  updateStatus(input: UpdateStatusInput!): Boolean!
  updateUserType(input: UpdateUserTypeInput!): Boolean!
  updateGender(input: UpdateGenderInput!): Boolean!

  adminUpdateUserNickname(username: String!, nickname: String!): JSON!
  adminUpdateUserEmail(username: String!, email: String!): JSON!
  adminUpdateUserPhone(username: String!, phone: String!): JSON!
  adminUpdateUserGender(username: String!, gender: Int!): JSON!
  adminUpdateUserType(username: String!, userType: Int!): JSON!
  adminUpdateUserStatus(username: String!, status: Int!): JSON!
  deleteUser(username: String!): Boolean!

  createFirstLevelCategory(input: JobCategoryCreateInput!): JobCategory!
  createSecondLevelCategory(input: JobCategoryCreateInput!): JobCategory!
  updateCategory(input: JobCategoryUpdateInput!): JobCategory!
  deleteFirstLevelCategory(categoryId: ID!): Boolean!
  deleteSecondLevelCategory(categoryId: ID!): Boolean!

  createJob(input: JobCreateInput!): Job!
  updateJob(input: JobUpdateInput!): Job!
  deleteJob(jobId: ID!): Boolean!

  addChoiceQuestion(input: ChoiceQuestionInput!): String!
  updateChoiceQuestion(input: ChoiceQuestionInput!): String!
  deleteChoiceQuestion(id: ID!): Boolean!
  submitInterviewAnswers(input: InterviewSubmitInput!): InterviewSubmitResult!

  createScenarioQuestion(input: ScenarioQuestionInput!): String!
  updateScenarioQuestion(input: ScenarioQuestionInput!): String!
  deleteScenarioQuestion(id: ID!): Boolean!

  extractResumeContent(file: Upload!): String!
  saveResumeAnalysisHistory(input: SaveResumeHistoryInput!, evaluationType: String = "SPECIAL"): ID!
  restoreResume(resumeHistoryId: ID!): ResumeContent!

  saveScenarioAnalysisHistory(input: SaveScenarioAnalysisHistoryInput!, evaluationType: String = "SPECIAL"): Boolean!

  saveComprehensiveResumeHistory(input: ComprehensiveResumeHistoryInput!): ComprehensiveResumeHistory!
  saveComprehensiveQuestionHistory(input: ComprehensiveQuestionHistoryInput!): ComprehensiveQuestionHistory!
  saveComprehensiveScenarioHistory(input: ComprehensiveScenarioHistoryInput!): ComprehensiveScenarioHistory!
  saveComprehensiveReport(input: ComprehensiveReportInput!): ComprehensiveReportHistory!

  submitFeedback(input: FeedbackSubmitInput!): Feedback!
  replyFeedback(input: FeedbackReplyInput!): Feedback!

  createBlessing(input: BlessingCreateInput!): Blessing!
  updateBlessing(id: ID!, input: BlessingUpdateInput!): Blessing!
  deleteBlessing(id: ID!): Boolean!

  saveChatMessage(input: ChatMessageSaveInput!): ChatMessage!
  upsertAgentConversation(input: AgentConversationUpsertRequest!): AgentConversationResponse!
  deleteAgentConversation(sessionId: ID!): Boolean!

  synthesizeSpeech(input: SpeechSynthesisInput!): String!
  analyzeFace(file: Upload!): String!
  uploadAudio(file: Upload!): String!
  createTranscriptionTask(audioUrl: String!): String!
  getAgentAnswer(input: AgentInput!): JSON!
}

input RegisterInput {
  username: String!
  password: String!
  confirmPassword: String!
  email: String
  phone: String
}

input LoginInput {
  username: String!
  password: String!
}

input ForgotSendCodeInput {
  email: String
  phone: String
}

input ForgotResetInput {
  email: String
  phone: String
  code: String!
  newPassword: String!
}

input UpdateEyeModeInput {
  eyeCareMode: Int!
}

input UpdateSurpriseModeInput {
  surpriseMode: Int!
}

input UpdateNicknameInput {
  nickname: String!
}

input UpdateAvatarInput {
  avatarUrl: String!
}

input UpdatePasswordInput {
  oldPassword: String!
  newPassword: String!
}

input BindEmailInput {
  email: String!
}

input BindPhoneInput {
  phone: String!
}

input UpdateStatusInput {
  status: Int!
}

input UpdateUserTypeInput {
  userType: Int!
}

input UpdateGenderInput {
  gender: Int!
}

input JobCategoryCreateInput {
  name: String!
  level: Int!
  parentId: ID
  sortOrder: Int = 0
}

input JobCategoryUpdateInput {
  id: ID!
  name: String!
  level: Int
  parentId: ID
  sortOrder: Int
  status: Int
}

input JobCreateInput {
  categoryId: ID!
  name: String!
  description: String!
  requirements: String!
}

input JobUpdateInput {
  id: ID!
  categoryId: ID!
  name: String!
  description: String!
  requirements: String!
  status: Int
}

input ChoiceQuestionInput {
  id: ID
  jobId: ID!
  question: String!
  options: String
  correctAnswer: String
  explanation: String
  difficulty: Int
  score: Int
}

input SubmittedAnswerInput {
  questionId: ID!
  answer: String!
}

input InterviewSubmitInput {
  jobId: ID
  answers: [SubmittedAnswerInput!]!
}

input ScenarioQuestionInput {
  id: ID
  jobId: ID!
  question: String!
}

input ResumeFeedbackInput {
  advantages: String
  disadvantages: String
  improvementSuggestions: String
}

input ResumeCompetenciesScoreInput {
  professionalSkills: Int
  projectExecution: Int
  innovation: Int
  communication: Int
  adaptability: Int
}

input SaveResumeHistoryInput {
  id: ID
  userId: ID!
  jobId: ID
  resumeContent: String
  score: Int
  feedback: ResumeFeedbackInput
  competenciesScore: ResumeCompetenciesScoreInput
}

input SaveScenarioAnalysisHistoryInput {
  userId: ID!
  totalScore: Int
  score1: Int
  suggestion1: String
  score2: Int
  suggestion2: String
  score3: Int
  suggestion3: String
  score4: Int
  suggestion4: String
  score5: Int
  suggestion5: String
}

input ComprehensiveResumeHistoryInput {
  userId: ID!
  jobId: ID
  fileName: String
  fileSize: Int
  fileType: String
  overallScore: Int
  skillMatch: Int
  experienceMatch: Int
  educationMatch: Int
  communicationSkill: Int
  leadershipSkill: Int
  aiAnalysis: String
  aiSuggestions: String
}

input ComprehensiveQuestionHistoryInput {
  userId: ID!
  jobId: ID
  startTime: DateTime
  endTime: DateTime
  totalTime: Int
  overallScore: Int
  aiSuggestions: String
}

input ComprehensiveScenarioHistoryInput {
  userId: ID!
  jobId: ID
  startTime: DateTime
  endTime: DateTime
  totalTime: Int
  overallScore: Int
  fluencyScore: Int
  emotionScore: Int
  relevanceScore: Int
  adaptabilityScore: Int
  aiAssessment: String
}

input ComprehensiveReportInput {
  userId: ID!
  jobId: ID
  overallScore: Float
  resumeScore: Float
  questionScore: Float
  scenarioScore: Float
  strengthAnalysis: String
  improvementAnalysis: String
  learningRoute: String
}

input FeedbackSubmitInput {
  type: String!
  title: String!
  content: String!
}

input FeedbackReplyInput {
  id: ID!
  reply: String!
  status: String!
}

input BlessingCreateInput {
  content: String!
  type: String
}

input BlessingUpdateInput {
  content: String!
  type: String
  status: String
}

input ChatMessageSaveInput {
  content: String!
}

input AgentConversationMessageResponseInput {
  type: String!
  content: String!
  time: String
}

input AgentConversationUpsertRequest {
  sessionId: String!
  agentKey: String
  jobId: ID
  title: String
  selectedEvaluationMode: String
  hasInteractedWithAssistant: Boolean
  hasShownWelcomeMessage: Boolean
  firstQuestionAt: DateTime
  assistantActions: JSON
  eventLogs: JSON
  aiMessages: [AgentConversationMessageResponseInput!]
  comprehensiveState: JSON
}

input SpeechSynthesisInput {
  text: String!
  vcn: String
  pitch: Int
  speed: Int
  tte: String
  audioPath: String
}

input AgentInput {
  agentKey: String
  params: JSON
  sessionId: String
  systemContent: String
  userContent: String
}
